# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Scraper / API Abstraction
# CarGurus (unofficial — rotate if needed)
CARGURUS_API_KEY=

# RapidAPI (for AutoTrader, Cars.com wrappers)
RAPIDAPI_KEY=

# Optional: Proxy service to avoid rate limits
SCRAPER_PROXY_URL=
SCRAPER_PROXY_KEY=

# Revalidation interval for cached listings (seconds)
LISTINGS_CACHE_TTL=900

# Market value calculation (based on recent sold prices)
MARKET_VALUE_CACHE_TTL=3600
